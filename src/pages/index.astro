---
import Projects from "../components/react/projects";
import Layout from "../layouts/Layout.astro";
import Footer from "../components/react/footer";
import NowPlaying from "../components/react/NowPlaying";

const links = [
  { title: "GitHub", url: "https://github.com/akinloluwami" },
  { title: "Email", url: "mailto:akinkunmioye42@gmail.com" },
  { title: "Twitter", url: "https://twitter.com/akinkunmi" },
];
---

<Layout title="Akinkunmi">
  <header class="mb-16 sm:mb-20">
    <h1
      class="font-serif text-[clamp(2.125rem,8vw,3.25rem)] font-normal text-off-white leading-[1.08] tracking-[-0.02em] mb-5"
    >
      Akinkunmi
    </h1>
    <p
      class="text-2xs uppercase tracking-[0.22em] text-muted mb-3 max-w-md leading-relaxed"
    >
      Software engineer
    </p>
    <p class="text-sm text-muted mb-10 max-w-md leading-relaxed">
Creator of
      <a
        href="https://byteship.dev"
        target="_blank"
        rel="noreferrer"
        class="group inline-flex items-center gap-1.5 text-off-white hover:text-accent transition-colors ml-0.5"
      >
        <svg
          class="shrink-0 w-[1.25em] h-[1.25em] translate-y-px text-current"
          width="625"
          height="665"
          viewBox="0 0 625 665"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path
            fill-rule="evenodd"
            clip-rule="evenodd"
            d="M620.77 214.466L622.661 324.838L624.552 435.209C626.444 482.252 624.552 500.346 573.489 527.486L473.254 585.386L376.802 643.285C333.304 666.807 316.282 674.045 265.219 646.904L163.093 592.623L62.8581 540.152C19.3599 516.63 4.23006 505.774 4.23006 451.493L2.33883 339.312L0.447604 228.941C-1.44362 181.898 0.447605 163.804 51.5107 136.664L151.746 78.7642L248.198 22.674C291.697 -2.65708 308.718 -9.89453 359.781 17.2459L461.907 71.5268L562.142 123.998C605.64 147.52 620.77 158.376 620.77 214.466ZM274.676 292.269L227.395 277.794C223.612 277.794 221.721 277.794 217.939 281.413C212.265 286.841 204.7 292.269 199.026 297.697C180.114 313.981 176.332 313.981 197.135 328.456C204.7 333.884 210.374 337.503 216.047 342.931C219.83 344.741 227.395 359.215 231.177 364.643C229.286 366.453 212.265 375.5 208.483 377.309C149.855 315.791 95.0089 408.068 93.1177 259.7C91.2265 227.132 93.1177 212.657 129.051 194.563L199.026 152.948L267.111 113.142C297.37 95.0485 310.609 91.4298 344.651 111.333L418.409 149.329L488.384 185.517C518.644 201.801 529.991 209.038 529.991 248.844L531.882 326.647L533.774 404.449C533.774 438.827 531.882 451.493 495.949 469.587L425.974 511.202L357.889 551.008C291.697 590.814 155.528 525.677 212.265 449.684C223.612 435.209 227.395 413.496 219.83 397.212C223.612 395.403 240.633 384.546 242.525 384.546C246.307 388.165 255.763 402.64 257.654 408.068C257.654 409.878 259.546 415.306 259.546 418.924L263.328 438.827C265.219 442.446 265.219 447.874 269.002 449.684C272.784 451.493 274.676 449.684 280.349 447.874L314.391 437.018C321.956 433.399 323.847 433.399 323.847 426.162C325.739 420.734 333.304 384.546 333.304 382.737C338.977 377.309 348.433 371.881 355.998 368.262C386.258 348.359 427.865 317.6 444.886 288.65C448.668 279.603 460.016 259.7 454.342 250.654C448.668 239.797 424.082 239.797 414.626 239.797C386.258 241.607 352.216 254.272 323.847 266.938C316.282 270.557 308.718 274.175 301.153 277.794C291.697 283.222 284.132 288.65 274.676 292.269ZM304.935 333.884C289.805 319.409 267.111 341.122 282.24 355.597C297.37 368.262 320.065 348.359 304.935 333.884ZM363.563 299.506C355.998 294.078 344.651 290.46 335.195 299.506C329.521 304.935 325.739 315.791 335.195 324.838C340.868 332.075 354.107 333.884 361.672 326.647C369.237 319.409 371.128 306.744 363.563 299.506Z"
            fill="#9FE871"
          />
        </svg>
        <span
          class="underline underline-offset-[5px] decoration-white/20 group-hover:decoration-accent/60"
        >
          Byteship
        </span>
      </a>
      and
      <a
        href="https://outray.dev"
        target="_blank"
        rel="noreferrer"
        class="group inline-flex items-center gap-1.5 text-off-white hover:text-accent transition-colors ml-0.5"
      >
        <svg
          class="shrink-0 w-[1.05em] h-[1.05em] translate-y-px text-current"
          width="170"
          height="170"
          viewBox="0 0 170 170"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path
            d="M2.54688 69.0371C34.9492 54.512 71.4883 58.7316 94.1689 82.6191C115.062 104.625 118.677 137.51 106.465 167.264C100.649 168.777 94.592 169.688 88.3623 169.931C103.925 145.463 102.096 113.376 82.0039 92.2148C60.6364 69.71 25.8588 67.1916 0 84.7705C0.0139808 79.4947 0.508598 74.3316 1.44238 69.3232C1.80382 69.2936 2.17561 69.2035 2.54688 69.0371ZM0.396484 93.2607C22.6416 86.6935 47.2006 92.139 63.7324 109.551C79.2799 125.926 83.8902 148.843 77.9697 169.71C73.0962 169.311 68.3394 168.5 63.7334 167.313C72.3879 150.763 70.0698 129.867 56.4922 115.566C42.278 100.596 20.2053 97.5726 2.82812 106.821C1.66514 102.43 0.843937 97.9001 0.396484 93.2607ZM5.04883 113.923C18.9587 111.941 33.5857 116.494 43.9971 127.46C53.8606 137.849 57.7793 151.718 55.8682 164.873C50.5667 162.939 45.5128 160.491 40.7646 157.592C42.2487 153.413 42.5813 148.771 41.4678 144.138C38.4078 131.407 25.606 123.567 12.875 126.627C12.2896 126.768 11.7145 126.928 11.1504 127.109C8.75847 122.924 6.71068 118.516 5.04883 113.923ZM84.999 0C131.943 0.000177301 169.998 38.0562 169.998 85C169.998 118.651 150.442 147.733 122.076 161.506C145.102 127.778 145.223 84.9804 119.838 58.2432C91.1585 28.0369 40.319 29.2765 3.70508 60.1006C14.3493 25.3058 46.7188 0 84.999 0Z"
            fill="currentColor"
          />
        </svg>
        <span
          class="underline underline-offset-[5px] decoration-white/20 group-hover:decoration-accent/60"
        >
          OutRay
        </span>
      </a>.
    </p>
    <p class="flex flex-wrap items-center gap-x-3 gap-y-2 text-sm text-muted">
      {
        links.map((link, i) => (
          <>
            {i > 0 ? (
              <span class="text-muted-faint/35 select-none text-xs" aria-hidden>
                ·
              </span>
            ) : null}
            <a
              href={link.url}
              target="_blank"
              rel="noreferrer"
              class="text-muted hover:text-accent underline-offset-[5px] decoration-white/20 hover:decoration-accent/60 underline transition-colors"
            >
              {link.title}
            </a>
          </>
        ))
      }
    </p>
    <div class="mt-8 max-w-md">
      <NowPlaying client:load />
    </div>
  </header>
  <Projects />
  <Footer />
</Layout>
